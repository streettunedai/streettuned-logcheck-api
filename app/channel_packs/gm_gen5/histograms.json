{
  "platform": "gm_gen5",
  "histograms": [
    {
      "name": "gm_airmass_error_by_maf_hz",
      "purpose": "Populate MAF correction by frequency in closed loop.",
      "x_axis": {
        "channel": "MAF_Hz",
        "units": "Hz"
      },
      "y_axis": {
        "channel": "RPM",
        "units": "rpm"
      },
      "z_value": {
        "metric": "STFT1_pct + LTFT1_pct",
        "aggregation": "mean"
      },
      "cell_ranges": {
        "x_bins": [
          1000,
          1500,
          2000,
          2500,
          3000,
          3500,
          4000,
          4500,
          5000,
          5500,
          6000,
          6500,
          7000,
          7500,
          8000,
          8500,
          9000,
          9500,
          10000,
          10500,
          11000,
          11500,
          12000
        ],
        "y_bins": [
          400,
          800,
          1200,
          1600,
          2000,
          2400,
          2800,
          3200,
          3600,
          4000,
          4400,
          4800,
          5200,
          5600,
          6000,
          6400
        ]
      },
      "filters": [
        "ECT_C > 70",
        "EQ_Cmd <= 1.02",
        "Throttle_Actual_pct < 45",
        "RPM > 900"
      ],
      "smoothing_guidance": "Use 0.2 to 0.35 exponential smoothing before applying curve changes.",
      "required_channels": [
        "MAF_Hz",
        "RPM",
        "STFT1_pct",
        "LTFT1_pct",
        "ECT_C",
        "EQ_Cmd",
        "Throttle_Actual_pct"
      ],
      "when_not_to_use": [
        "Do not use during PE, DFCO, or transient throttle stabs."
      ]
    },
    {
