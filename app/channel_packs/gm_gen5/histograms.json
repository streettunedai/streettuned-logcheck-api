    {
      "name": "gm_wot_lambda_error_rpm",
      "purpose": "Compare commanded EQ/lambda against measured lambda at WOT.",
      "x_axis": {
        "channel": "RPM",
        "units": "rpm"
      },
      "y_axis": {
        "channel": "TransGear",
        "units": "gear"
      },
      "z_value": {
        "metric": "Lambda - (1 / EQ_Cmd)",
        "aggregation": "mean"
      },
      "cell_ranges": {
        "x_bins": [
          2000,
          2500,
          3000,
          3500,
          4000,
          4500,
          5000,
          5500,
          6000,
          6500,
          7000
        ],
        "y_bins": [
          "gear_by_log"
        ]
      },
      "filters": [
        "Throttle_Actual_pct > 88",
        "APP_pct > 75",
        "EQ_Cmd > 1.05"
      ],
      "smoothing_guidance": "No smoothing beyond light moving average; retain transient enrichment shape.",
      "required_channels": [
        "RPM",
        "TransGear",
        "Lambda",
        "EQ_Cmd",
        "Throttle_Actual_pct",
        "APP_pct"
      ],
      "when_not_to_use": [
        "Do not use if no wideband channel or if lambda sensor response is delayed/filtered heavily."
      ]
    },
