        "units": "kPa"
      },
      "y_axis": {
        "channel": "RPM",
        "units": "rpm"
      },
      "z_value": {
        "metric": "STFT1_pct + LTFT1_pct",
        "aggregation": "mean"
      },
      "cell_ranges": {
        "x_bins": [
          20,
          30,
          40,
