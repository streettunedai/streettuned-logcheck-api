{
  "version": "1.0.0",
  "normalization": {
    "case_insensitive": true,
    "trim_whitespace": true,
    "collapse_internal_spaces": true,
    "strip_bom": true
  },
  "sae_alias_handling": {
    "strategy": "treat \"(SAE)\" suffix/prefix as equivalent",
    "examples": [
      {
        "raw": "Engine Speed (SAE)",
        "canonical": "RPM"
      },
      {
        "raw": "Intake Manifold Absolute Pressure (SAE)",
        "canonical": "MAP_kPa"
      }
    ]
  },
  "raw_to_canonical": {
    "Engine Speed (SAE)": "RPM",
    "Engine RPM": "engine_rpm",
    "RPM": "engine_rpm",
    "Vehicle Speed (SAE)": "VSS_mph",
    "Vehicle Speed": "vehicle_speed",
    "MPH": "VSS_mph",
    "Intake Manifold Absolute Pressure (SAE)": "MAP_kPa",
    "MAP (SAE)": "MAP_kPa",
    "MAP": "map_kpa",
    "Boost/Vacuum": "Boost_kPa",
    "Boost Pressure": "Boost_kPa",
    "Fuel Rail Pressure": "rail_pressure_actual",
    "Rail Pressure": "rail_pressure_actual",
    "Desired Fuel Rail Pressure": "rail_pressure_commanded",
    "Fuel Rail Pressure (MPa)": "RailPressure_MPa",
    "Fuel Rail Pressure Desired": "rail_pressure_commanded",
    "Throttle Position": "throttle_position",
    "Desired Throttle Position": "Throttle_Desired_pct",
    "Accelerator Pedal Position": "apps",
    "APP": "apps",
    "Commanded EQ Ratio": "EQ_Cmd",
    "Equivalence Ratio Commanded (SAE)": "EQ_Cmd",
    "Lambda 1": "Lambda",
    "Wideband Lambda": "Lambda",
    "Knock Retard": "KR_deg",
    "Total Knock Retard": "KR_deg",
    "Trans Gear": "TransGear",
    "Current Gear": "TransGear",
    "Boost PSI": "boost_psi",
    "Boost": "boost_psi",
    "EGT": "egt",
    "Exhaust Gas Temp": "egt",
    "Intake Air Temp": "intake_air_temp",
    "Coolant Temp": "coolant_temp",
    "Lift Pump Pressure": "fuel_pressure",
    "Fuel Pressure": "fuel_pressure",
    "Injection Quantity": "injection_quantity",
    "Injector Pulse Width": "pulse_width",
    "Gear": "gear",
    "Converter Slip": "converter_slip",
    "TCC Lockup": "lockup"
  }
}
